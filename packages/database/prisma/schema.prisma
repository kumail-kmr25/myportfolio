  clientName      String
  projectTitle    String
  status          String
  startDate       DateTime
  expectedEndDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemConfig {
  id                String   @id @default(uuid())
  maxActiveProjects Int      @default(2)
  manualOverride    String?
  overrideMessage   String?
  updatedAt         DateTime @updatedAt
}

