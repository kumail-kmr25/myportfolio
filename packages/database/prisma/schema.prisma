  name      String
  status    String   @default("expert") // expert, intermediate, learning
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id        String   @id @default(uuid())
  url       String
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id                    String    @id @default(cuid())
  siteName              String?   @default("Kumail KMR")
  siteUrl               String?   @default("https://kumailkmr.vercel.app")
  heroHeadline          String?
  heroSubheadline       String?
  aboutText             String?
  calendlyUrl           String?
