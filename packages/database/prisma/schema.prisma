  @@index([createdAt])
}

model ConversionEvent {
  id        String   @id @default(cuid())
  type      String // estimate, audit, contact, download, booking
  source    String?
  value     Int?
  userId    String?
  email     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([email])
}

model Promotion {
  id              String   @id @default(cuid())
  name            String
