  linkedinUrl           String?
  githubUrl             String?
  twitterUrl            String?
  whatsappNumber        String?
  metaTitle             String?
  metaDescription       String?
  googleAnalyticsId     String?
  facebookPixelId       String?
  updatedAt             DateTime  @updatedAt
}

// ============================================
// ANALYTICS & TRACKING
// ============================================

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
