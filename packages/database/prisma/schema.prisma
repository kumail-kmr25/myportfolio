  slug        String?   @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  category    String?
  published   Boolean   @default(false)
  status      String    @default("draft")
  readTime    String?
  views       Int       @default(0)
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([status])
}

model IssuePattern {
  id                 String   @id @default(uuid())
  keywords           String[]
  possibleCauses     String[]
  debugSteps         String[]
  complexity         String
  recommendedService String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DiagnosticLog {
  id               String   @id @default(uuid())
  description      String
  techStack        String?
  errorMessage     String?
  environment      String
  matchedPatternId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FeatureRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  category  String
