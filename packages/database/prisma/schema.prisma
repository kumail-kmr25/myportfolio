// TIER 1: INSTANT CLIENT MAGNETS
// ═══════════════════════════════════════

// Feature 1: AI Chat Assistant
model AIChatConfig {
  id                    String    @id @default(cuid())
  enabled               Boolean   @default(false)
  botName               String    @default("Kumail KMR Assistant")
  welcomeMessage        String    @default("Hi! How can I help you today?")
  widgetPosition        String    @default("bottom-right")
  widgetColor           String    @default("#2563eb")
  avatarUrl             String?
  showAfterSeconds      Int       @default(30)
  showOnPages           String[]  @default(["all"])
  maxMessagesPerSession Int       @default(10)
  systemPrompt          String?
  quickQuestions        String[]
  customResponses       Json?
  updatedAt             DateTime  @updatedAt
}

model AIChatConversation {
  id              String    @id @default(cuid())
  sessionId       String
  visitorEmail    String?
  visitorName     String?
  visitorPhone    String?
  messages        Json
  messageCount    Int       @default(0)
  emailCaptured   Boolean   @default(false)
  leadScore       Int?
  leadQuality     String?
  resolved        Boolean   @default(false)
  adminNotes      String?
  ipAddress       String?
  userAgent       String?
  pageUrl         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([sessionId])
  @@index([visitorEmail])
}

// Feature 2: Video Walkthroughs
model ProjectVideo {
  id             String   @id @default(cuid())
  projectId      String?
  title          String
  description    String?
  videoUrl       String
  videoType      String   @default("upload") // upload, youtube, vimeo, loom
  thumbnailUrl   String?
  duration       Int? // seconds
  captionsUrl    String?
  transcript     String?
  enabled        Boolean  @default(true)
  featured       Boolean  @default(false)
  order          Int      @default(0)
  viewCount      Int      @default(0)
  avgWatchTime   Float?
  completionRate Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([featured])
}

// Feature 3: Live Site Previews
model LivePreview {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  siteUrl     String
  defaultView String   @default("desktop") // desktop, tablet, mobile
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// Feature 4: Revenue Dashboard
model ClientRevenue {
  id                    String   @id @default(cuid())
  projectId             String?
  clientName            String
  industry              String
  monthlyRevenueBefore  Int?
  monthlyRevenueAfter   Int?
  totalRevenueGenerated Int      @default(0)
  conversionBefore      Float?
  conversionAfter       Float?
  trafficBefore         Int?
  trafficAfter          Int?
  currency              String   @default("INR")
  isLive                Boolean  @default(true) // Show on dashboard
  lastUpdated           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([projectId])
}

// Feature 5: Voice Introduction
model VoiceIntro {
  id         String   @id @default(cuid())
  enabled    Boolean  @default(false)
  audioUrl   String?
  duration   Int?
  transcript String?
  placement  String[] @default(["about"])
  playCount  Int      @default(0)
  updatedAt  DateTime @updatedAt
