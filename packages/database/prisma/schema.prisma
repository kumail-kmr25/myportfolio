generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  phone            String             @unique
  userId           String             @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  activityLogs     AdminActivityLog[]
}

model AdminActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model DeveloperStatus {
  id                   String   @id @default(uuid())
  status               String   @default("available")
  capacityPercent      Int      @default(0)
  nextAvailabilityDays Int      @default(0)
  currentFocus         String   @default("Open to new projects")
  customMessage        String?
  updatedAt            DateTime @updatedAt
}

model ActiveProject {
  id              String   @id @default(uuid())
  clientName      String
  projectTitle    String
  status          String
  startDate       DateTime
  expectedEndDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemConfig {
  id                String   @id @default(uuid())
  maxActiveProjects Int      @default(2)
  manualOverride    String?
  overrideMessage   String?
  updatedAt         DateTime @updatedAt
}

model Testimonial {
  id                  String   @id @default(uuid())
  name                String
  email               String
  company             String?
  relationship_type   String
  intervention_type   String
  message             String
  rating              Int
  about_delivery_lead String
  permission          Boolean  @default(false)
  approved            Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  featured            Boolean  @default(false)
  photoUrl            String?
  role                String?
  verified            Boolean  @default(false)
  deliveryRating      Int      @default(5)
}

model ContactSubmission {
  id              String   @id @default(uuid())
  name            String
  email           String
  company         String?
  inquiryType     String?
  serviceRequired String?
  budgetRange     String?
  timeline        String?
  message         String
  foundBy         String?
  replied         Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Project {
  id                 String   @id @default(uuid())
  title              String
  description        String
  tags               String[]
  image              String
  demo               String?
  github             String?
  beforeImageUrl     String?
  afterImageUrl      String?
  improvementDetails String?
  metrics            String[]
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  decisionLogs       String[]
  architecture       Json?
  backendDepth       Int      @default(0)
  challenges         String?
  engineering        String?
  isVisible          Boolean  @default(true)
  lessons            String?
  performance        String?
  problem            String?
  role               String?
  scalability        String?
  scalabilityDepth   Int      @default(0)
  security           String?
  securityDepth      Int      @default(0)
  solution           String?
  status             String   @default("Production")
  summary            String?
  targetAudience     String?
  uiDepth            Int      @default(0)
  valueProp          String?
  category           String?
  isFeatured         Boolean  @default(false)
  results            String?
  valuePoints        String[]
  gallery            String[]
  timeline           Json?
  systemArchitecture  Json?
  engineeringDecisions Json?
  codeSnippet         Json?
  realStats           Json?
}

model CaseStudy {
  id           String   @id @default(uuid())
  title        String
  errorMessage String
  rootCause    String
  steps        String[]
  solution     String
  impact       String
  techStack    String[]
  isPublished  Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  architecture Json?
}

model FeatureRequest {
  id         String   @id @default(uuid())
  name       String
  email      String
  message    String
  category   String
  status     String   @default("pending")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model SiteStats {
  id                       String   @id @default(uuid())
  totalProjects            Int      @default(0)
  bugsFixed                Int      @default(0)
  caseStudiesWritten       Int      @default(0)
  featureRequestsCompleted Int      @default(0)
  yearsLearning            Int      @default(0)
  deploymentCount          Int      @default(0)
  lastUpdated              DateTime @default(now())
}

model BlogPost {
  id         String   @id @default(uuid())
  title      String
  excerpt    String
  content    String
  category   String
  readTime   String
  published  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model IssuePattern {
  id                 String   @id @default(uuid())
  keywords           String[]
  possibleCauses     String[]
  debugSteps         String[]
  complexity         String
  recommendedService String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DiagnosticLog {
  id               String   @id @default(uuid())
  description      String
  techStack        String?
  errorMessage     String?
  environment      String
  matchedPatternId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HireRequest {
  id              String   @id @default(uuid())
  name            String
  email           String
  company         String?
  description     String
  selectedService String
  budgetRange     String
  timeline        String
  projectType     String
  source          String   @default("hire_me")
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contactMethod   String?
  referenceLink   String?
}

model JourneyPhase {
  id          String   @id @default(uuid())
  phase       String
  title       String
  description String
  icon        String
  color       String
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  actionLabel String?
  actionUrl   String?
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  status    String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id        String   @id @default(uuid())
  url       String
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
