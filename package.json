{
  "name": "portfolio-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "build": "next build client",
    "dev": "next dev client",
    "lint": "next lint client",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma --accept-data-loss",
    "db:migrate": "npx prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:sync": "npx prisma generate --schema=packages/database/prisma/schema.prisma && npx prisma db push --schema=packages/database/prisma/schema.prisma --accept-data-loss",
    "db:seed": "node packages/database/prisma/seed.js",
    "db:seed:production": "npx tsx packages/database/prisma/seed-production.ts",
    "db:seed:features": "node packages/database/prisma/seed_features.js",
    "db:seed:journey": "node packages/database/prisma/seed_journey.js",
    "seed:all": "npx tsx packages/database/prisma/seed-all.ts",
    "seed:admin": "npx tsx packages/database/prisma/seed-all.ts"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "prisma": "^6.2.1",
    "typescript": "^5"
  },
  "engines": {
    "node": "^22"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
